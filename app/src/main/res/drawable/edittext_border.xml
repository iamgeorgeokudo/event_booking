<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background -->
    <solid android:color="@android:color/white"/>

    <!-- Border -->
    <stroke
        android:width="1dp"
        android:color="#CCCCCC"/>

    <!-- Rounded corners -->
    <corners android:radius="12dp"/>

    <!-- Padding inside -->
    <padding
        android:left="12dp"
        android:top="12dp"
        android:right="12dp"
        android:bottom="12dp"/>

</shape>