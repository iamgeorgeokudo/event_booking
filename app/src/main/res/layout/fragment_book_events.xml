<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Book Event"
            android:textSize="22sp"
            android:fontFamily="@font/poppins_bold"
            android:textColor="@color/text_dark" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Pick an event and pay with M-Pesa"
            android:fontFamily="@font/poppins_medium"
            android:textSize="13sp"
            android:textColor="@color/text_hint" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Choose Event"
            android:textColor="@color/text_dark"
            android:fontFamily="@font/poppins_bold" />

        <Spinner
            android:id="@+id/spnDummyEvents"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/edittext_border"
            android:paddingHorizontal="12dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface_light"
            app:strokeColor="@color/gray_light"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvBookingEventTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Event Title"
                    android:textSize="17sp"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="@color/pink_primary" />

                <TextView
                    android:id="@+id/tvBookingDateVenue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Date • Venue"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_medium"
                    android:textColor="@color/text_hint" />

                <TextView
                    android:id="@+id/tvTicketPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Ticket Price: KES 0"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="@color/text_dark" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Number of Tickets"
            android:textColor="@color/text_dark"
            android:fontFamily="@font/poppins_bold" />

        <EditText
            android:id="@+id/etTicketQuantity"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/edittext_border"
            android:hint="e.g. 2"
            android:inputType="number"
            android:paddingStart="15dp" />

        <TextView
            android:id="@+id/tvBookingTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Total: KES 0"
            android:textColor="@color/pink_primary"
            android:textSize="16sp"
            android:fontFamily="@font/poppins_bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="M-Pesa Number"
            android:textColor="@color/text_dark"
            android:fontFamily="@font/poppins_bold" />

        <EditText
            android:id="@+id/etMpesaNumber"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/edittext_border"
            android:hint="07xx xxx xxx"
            android:inputType="phone"
            android:paddingStart="15dp" />

        <Button
            android:id="@+id/btnLipaNaMpesa"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="22dp"
            android:text="Pay with M-Pesa"
            android:textAllCaps="false"
            android:fontFamily="@font/poppins_bold"
            android:backgroundTint="@color/pink_primary"
            android:textColor="@color/white"
            app:cornerRadius="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            android:fontFamily="@font/poppins_medium"
            android:gravity="center"
            android:text="You will receive an M-Pesa STK push on your phone."
            android:textColor="@color/text_hint"
            android:textSize="12sp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>